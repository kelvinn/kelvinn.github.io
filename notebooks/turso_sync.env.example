# Required for bootstrap/sync write operations.
TURSO_AUTH_TOKEN=replace-with-group-token
# Required when your account has multiple groups.
TURSO_GROUP=health

# Optional configuration
TURSO_DB_ROOT=~/HealthData/DBs
TURSO_DB_PREFIX=health-

# Local state artifacts (non-secret)
TURSO_MAP_PATH=~/.config/turso-sync/turso-sync-map.json
TURSO_STATE_PATH=~/.config/turso-sync/turso-sync-state.json
TURSO_ENABLE_PATH=~/.config/turso-sync/enabled.flag
TURSO_SYNC_LOCK_PATH=~/.config/turso-sync/sync.lock
TURSO_SYNC_LOG_DIR=~/.config/turso-sync/logs
