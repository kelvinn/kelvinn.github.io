# Quarterly report config (KEY=VALUE)
# Copy to notebooks/report_config.env and adjust values for each run.

# Earliest date for long-history trend queries.
REPORT_QUERY_START_DATE=2019-01-01

# Inclusive quarter window used for quarter-specific charts/tables.
REPORT_QUARTER_START_DATE=2026-01-01
REPORT_QUARTER_END_DATE=2026-03-31

# Destination directory for generated images and CSV files.
# Can be relative to notebooks/ (default run location) or absolute.
REPORT_POST_OUTPUT_DIR=../content/posts/2026-q1-health-review
